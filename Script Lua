local cam = workspace.CurrentCamera
local CAM_POS = Vector3.new(-11.38, 35.72, -144.16)
local LOOK_TARGET = Vector3.new(-7.0, -18.5, -65.5)
local isLoop6, isLoop7 = false, false

local btn6 = Instance.new("TextButton")
btn6.Parent = RightScroll
btn6.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
btn6.Size = UDim2.new(1, -5, 0, 40)
btn6.Text = "⚠️⚠️⚠️ (6: Slide Edge)"
btn6.TextColor3 = Color3.new(1, 1, 1)
btn6.Font = Enum.Font.SourceSansBold
Instance.new("UICorner", btn6).CornerRadius = UDim.new(0, 8)
Instance.new("UIStroke", btn6).Color = Color3.fromRGB(255, 0, 0)

btn6.MouseButton1Click:Connect(function()
    isLoop6 = not isLoop6
    btn6.BackgroundColor3 = isLoop6 and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(35, 35, 55)
    if isLoop6 then
        cam.CameraType = Enum.CameraType.Scriptable
        cam.CFrame = CFrame.lookAt(CAM_POS, LOOK_TARGET)
    else
        cam.CameraType = Enum.CameraType.Custom
    end
    task.spawn(function()
        local p = {Vector3.new(-55.22, -18.5, -51.8), Vector3.new(-55.2, -18.5, -80), Vector3.new(41.1, -18.5, -79.6), Vector3.new(41.4, -18.5, -51.8), Vector3.new(-55.22, -18.5, -51.8)}
        while isLoop6 do
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for i = 1, #p - 1 do
                    for s = 0, 1, 0.05 do
                        if not isLoop6 then break end
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.CFrame = CFrame.new(p[i]:Lerp(p[i + 1], s))
                        runService.Heartbeat:Wait()
                    end
                end
            else task.wait(1) end
        end
    end)
end)

