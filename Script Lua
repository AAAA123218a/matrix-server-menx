local function CreateMenu(name, pos, size, title)
    local SG = Instance.new("ScreenGui")
    SG.Name = name
    SG.Parent = game:GetService("CoreGui")
    SG.Enabled = false

    local MF = Instance.new("Frame")
    MF.Parent = SG
    MF.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    MF.BorderSizePixel = 0
    MF.Position = pos
    MF.Size = size
    MF.Active = true
    MF.Draggable = true

    Instance.new("UICorner", MF).CornerRadius = UDim.new(0, 12)
    local stroke = Instance.new("UIStroke", MF)
    stroke.Thickness = 2
    stroke.Color = Color3.fromRGB(0, 255, 200)

    local TB = Instance.new("Frame")
    TB.Parent = MF
    TB.BorderSizePixel = 0
    TB.Size = UDim2.new(1, 0, 0, 28)
    TB.BackgroundColor3 = Color3.fromRGB(0, 170, 255)

    local TT = Instance.new("TextLabel")
    TT.Parent = TB
    TT.BackgroundTransparency = 1
    TT.Position = UDim2.new(0, 10, 0, 0)
    TT.Size = UDim2.new(1, -40, 1, 0)
    TT.Font = Enum.Font.SourceSansBold
    TT.Text = title
    TT.TextColor3 = Color3.fromRGB(255, 255, 255)
    TT.TextSize = 16
    TT.TextXAlignment = Enum.TextXAlignment.Left

    local SC = Instance.new("ScrollingFrame")
    SC.Parent = MF
    SC.BackgroundTransparency = 1
    SC.BorderSizePixel = 0
    SC.Position = UDim2.new(0, 6, 0, 32)
    SC.Size = UDim2.new(1, -12, 1, -38)
    SC.CanvasSize = UDim2.new(0, 0, 0, 450)
    SC.ScrollBarThickness = 5
    Instance.new("UIListLayout", SC).Padding = UDim.new(0, 4)

    return SC, MF, SG
end

