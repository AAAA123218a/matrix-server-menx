local runService=game:GetService("RunService")

local function CreateMenu(name,pos,size,title)
    local SG=Instance.new("ScreenGui")
    SG.Name=name
    SG.Parent=game:GetService("CoreGui")
    SG.ResetOnSpawn=false

    local MF=Instance.new("Frame")
    MF.Parent=SG
    MF.BackgroundColor3=Color3.fromRGB(35,35,35)
    MF.BorderSizePixel=0
    MF.Position=pos
    MF.Size=size
    MF.Active=true
    MF.Draggable=true

    local TB=Instance.new("Frame")
    TB.Parent=MF
    TB.BackgroundColor3=Color3.fromRGB(0,170,255)
    TB.BorderSizePixel=0
    TB.Size=UDim2.new(1,0,0,25)

    local TT=Instance.new("TextLabel")
    TT.Parent=TB
    TT.BackgroundTransparency=1
    TT.Position=UDim2.new(0,8,0,0)
    TT.Size=UDim2.new(1,-16,1,0)
    TT.Font=Enum.Font.SourceSansBold
    TT.Text=title
    TT.TextColor3=Color3.fromRGB(255,255,255)
    TT.TextSize=16
    TT.TextXAlignment=Enum.TextXAlignment.Left

    local SC=Instance.new("ScrollingFrame")
    SC.Parent=MF
    SC.BackgroundTransparency=1
    SC.BorderSizePixel=0
    SC.Position=UDim2.new(0,5,0,30)
    SC.Size=UDim2.new(1,-10,1,-35)
    SC.CanvasSize=UDim2.new(0,0,0,300)
    SC.ScrollBarThickness=6

    local UIL=Instance.new("UIListLayout")
    UIL.Parent=SC
    UIL.Padding=UDim.new(0,3)

    local corner=Instance.new("UICorner",MF)
    corner.CornerRadius=UDim.new(0,10)

    local stroke=Instance.new("UIStroke",MF)
    stroke.Thickness=2
    stroke.Color=Color3.fromRGB(0,170,255)

    local grad=Instance.new("UIGradient",stroke)
    grad.Color=ColorSequence.new{
        ColorSequenceKeypoint.new(0,Color3.fromRGB(0,170,255)),
        ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,0,255)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(0,255,170))
    }

    return SC,MF
end

