local btn6=Instance.new("TextButton")
btn6.Parent=RightScroll
btn6.BackgroundColor3=Color3.fromRGB(50,50,50)
btn6.BorderSizePixel=0
btn6.Size=UDim2.new(1,-5,0,40)
btn6.Font=Enum.Font.SourceSansBold
btn6.Text="⚠️⚠️⚠️ (6: Slide Edge)"
btn6.TextColor3=Color3.fromRGB(255,255,255)

Instance.new("UIStroke",btn6).Color=Color3.fromRGB(255,0,0)

btn6.MouseButton1Click:Connect(function()
    isLoop6=not isLoop6
    btn6.BackgroundColor3=isLoop6 and Color3.fromRGB(255,0,0) or Color3.fromRGB(50,50,50)
    if isLoop6 then cam.CameraType=Enum.CameraType.Scriptable cam.CFrame=CFrame.lookAt(CAM_POS,LOOK_TARGET) else cam.CameraType=Enum.CameraType.Custom end
    task.spawn(function()
        local p={Vector3.new(-55.22,-18.5,-51.8),Vector3.new(-55.2,-18.5,-80),Vector3.new(41.1,-18.5,-79.6),Vector3.new(41.4,-18.5,-51.8),Vector3.new(-55.22,-18.5,-51.8)}
        while isLoop6 do
            local hrp=game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for i=1,#p-1 do
                    for s=0,1 do
                        if not isLoop6 then break end
                        hrp.Velocity=Vector3.new(0,0,0)
                        hrp.CFrame=CFrame.new(p[i]:Lerp(p[i+1],s))
                        runService.Heartbeat:Wait()
                    end
                end
            else task.wait(1) end
        end
    end)
end)

